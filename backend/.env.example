# Copy to backend/.env and fill in your Postgres password.
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@localhost:5432/apex

# Synthetic data generator
APEX_RANDOM_SEED=42

# Non-prod email sink — all outbound Analyser email routes here (set to your inbox).
APEX_DEMO_EMAIL=you@example.com

# Agentic loop — Groq LLM inference (reasoning narrative + customer messages).
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Analyser outbound email (Resend free tier). All mail routes to APEX_DEMO_EMAIL above.
# Test mode: leave APEX_EMAIL_FROM as the default and the recipient must be your own
# Resend account email. To send freely, verify a domain and set a from-address on it.
RESEND_API_KEY=re_your_key_here
APEX_EMAIL_FROM=APEX (SBI) <onboarding@resend.dev>

# Base URL the API is reachable at — used for click-tracking links inside emails.
APEX_PUBLIC_URL=http://localhost:8000
